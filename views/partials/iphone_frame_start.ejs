<!-- iPhone 14 Pro 模拟框架 - 开始 -->
<style>
/* iPhone 设备框架 */
.iphone-bg{
  background: linear-gradient(135deg, #d1d5db 0%, #e5e7eb 50%, #d1d5db 100%);
  display: flex; justify-content: center; align-items: center;
  min-height: 100vh; padding: 24px 0;
}
.iphone-device{
  width: 375px; background: #000;
  border-radius: 50px; padding: 6px;
  box-shadow:
    0 0 0 1px rgba(0,0,0,.08),
    0 4px 12px rgba(0,0,0,.12),
    0 18px 48px rgba(0,0,0,.25),
    0 48px 80px rgba(0,0,0,.1);
  position: relative; flex-shrink: 0;
  transform: scale(0.92); transform-origin: center center;
}
/* 屏幕容器 */
.iphone-screen{
  display: flex; flex-direction: column;
  background: #f5f7fa; border-radius: 44px;
  height: 720px; position: relative; overflow: hidden;
}
/* 内容区可滚动 */
.iphone-screen-scroll{
  flex: 1; overflow-y: auto; overflow-x: hidden;
  -webkit-overflow-scrolling: touch;
}
.iphone-screen-scroll::-webkit-scrollbar{ width: 0; display: none; }

/* TabBar — 固定在屏幕底部（sticky 到底部） */
.iphone-screen .m-tabbar{
  flex-shrink: 0;
  position: sticky; bottom: 0;
  z-index: 200;
  margin: 0;
  /* 覆盖 head 原始 fixed 样式 */
  position: sticky !important;
  bottom: 0 !important;
  left: 0 !important; right: 0 !important;
  max-width: 100% !important;
  margin: 0 !important;
  transform: none !important;
}

/* 刘海/动态岛 */
.iphone-notch-overlay{position: absolute; top: 0; left: 0; right: 0; z-index: 300; pointer-events: none; height: 0;}
.iphone-notch-bg{position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 150px; height: 34px; background: #000; border-radius: 0 0 20px 20px; pointer-events: auto;}
.iphone-dynamic-island{position: absolute; top: 10px; left: 50%; transform: translateX(-50%); width: 108px; height: 22px; background: #1c1c1e; border-radius: 12px;}
.iphone-dot-right{position: absolute; top: 12px; right: 80px; width: 8px; height: 8px; background: #f97316; border-radius: 50%; opacity: .9;}
.iphone-dot-left{position: absolute; top: 12px; left: 80px; width: 8px; height: 8px; background: #22c55e; border-radius: 50%; opacity: .6;}

/* Home Bar */
.iphone-home-bar{height: 20px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; background: #000; border-radius: 0 0 44px 44px;}
.iphone-home-bar .hb-line{width: 120px; height: 4px; background: rgba(255,255,255,.25); border-radius: 2px; margin-bottom: 6px;}

/* 侧边按钮 */
.iphone-buttons{position: absolute; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none; z-index: 1;}
.iphone-btn-power{position: absolute; right: -4px; top: 165px; width: 4px; height: 55px; background: #2a2a2a; border-radius: 0 2px 2px 0;}
.iphone-btn-vol-up{position: absolute; left: -4px; top: 155px; width: 4px; height: 34px; background: #2a2a2a; border-radius: 2px 0 0 2px;}
.iphone-btn-vol-down{position: absolute; left: -4px; top: 202px; width: 4px; height: 34px; background: #2a2a2a; border-radius: 2px 0 0 2px;}
.iphone-btn-silent{position: absolute; left: -4px; top: 62px; width: 4px; height: 20px; background: #2a2a2a; border-radius: 2px 0 0 2px;}

/* 重置 body */
body.iphone-host{ max-width: none !important; background: transparent !important; min-height: 0 !important; margin: 0 !important; }
.iphone-screen .m-shell{ min-height: auto; }
.iphone-screen .m-login{ min-height: 0 !important; height: auto; }
</style>
<div class="iphone-bg">
  <div class="iphone-device">
    <div class="iphone-buttons">
      <div class="iphone-btn-silent"></div>
      <div class="iphone-btn-vol-up"></div>
      <div class="iphone-btn-vol-down"></div>
      <div class="iphone-btn-power"></div>
    </div>
    <div class="iphone-notch-overlay">
      <div class="iphone-dot-left"></div>
      <div class="iphone-dot-right"></div>
      <div class="iphone-notch-bg">
        <div class="iphone-dynamic-island"></div>
      </div>
    </div>
    <div class="iphone-screen">
      <div class="iphone-screen-scroll">
