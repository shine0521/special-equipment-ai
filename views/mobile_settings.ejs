<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta http-equiv="Cache-Control" content="no-cache,no-store,must-revalidate">
<title>系统设置 · 特种设备AI</title>
<style>
:root{--p:#409eff;--s:#67c23a;--d:#f56c6c;--w:#e6a23c;--bg:#f5f7fa;--card:#fff;--tx:#303133;--t2:#606266;--t3:#909399;--t4:#c0c4ce;--bd:#dcdfe6;--bdr:8px}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{font:13px/1.5 -apple-system,BlinkMacSystemFont,'PingFang SC','Microsoft YaHei',sans-serif;background:var(--bg);color:var(--tx);margin:0 auto;min-height:100vh;max-width:480px}
.m-shell{min-height:100vh;padding-bottom:56px}
.m-topbar{background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:#fff;padding:14px 16px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50}
.m-topbar .tl{font-size:15px;font-weight:600}
.m-content{padding:10px}

.m-card{background:var(--card);border-radius:var(--bdr);padding:12px;margin-bottom:10px;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.m-card-h{font-size:13px;font-weight:600;margin-bottom:10px}

/* ── 头像卡片 ── */
.m-avatar-card{display:flex;align-items:center;gap:12px;padding:12px;background:var(--card);border-radius:var(--bdr);margin-bottom:10px;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.m-avatar{width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;flex-shrink:0}
.m-avatar-info{flex:1;min-width:0}
.m-avatar-info .an{font-size:15px;font-weight:600}
.m-avatar-info .ae{font-size:11px;color:var(--t2);margin-top:2px}

/* ── 行 ── */
.m-row{display:flex;justify-content:space-between;align-items:center;padding:11px 0;border-bottom:1px solid #f0f0f0;font-size:12px}
.m-row:last-child{border-bottom:none}
.m-row .rl{color:var(--t3);display:flex;align-items:center;gap:4px}
.m-row .rr{color:var(--tx);text-align:right;word-break:break-all}
.m-row .rr .m-tag{display:inline-block;padding:2px 6px;border-radius:3px;font-size:10px;font-weight:600}

.m-tag{display:inline-block;padding:2px 6px;border-radius:3px;font-size:10px;font-weight:600}
.m-tag-ok{background:#f0f9eb;color:var(--s)}
.m-tag-ng{background:#fef0f0;color:var(--d)}
.m-tag-mb{background:#fdf6ec;color:var(--w)}
.m-tag-info{background:#ecf5ff;color:var(--p)}

.m-btn{display:block;width:100%;padding:11px;border:none;border-radius:6px;font-size:13px;font-weight:500;cursor:pointer;text-align:center;transition:opacity .15s}
.m-btn:active{opacity:.8}
.m-btn-d{background:var(--d);color:#fff}

/* ── 关于脚注 ── */
.m-footer{text-align:center;padding:12px 10px 8px;font-size:10px;color:var(--t4)}

/* ── 确认弹窗 ── */
.m-overlay{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;display:flex;align-items:center;justify-content:center;padding:16px}
.m-modal{background:#fff;border-radius:12px;max-width:300px;width:100%;overflow:hidden;animation:mFadeIn .18s ease}
@keyframes mFadeIn{from{opacity:0;transform:scale(.93)}to{opacity:1;transform:scale(1)}}
.m-modal-b{padding:20px 16px 16px;text-align:center}
.m-modal-b .mq{font-size:36px;display:block;margin-bottom:6px}
.m-modal-b .mt{font-size:15px;font-weight:600;margin-bottom:4px}
.m-modal-b .md{font-size:12px;color:var(--t2);margin-bottom:16px}
.m-modal-actions{display:flex;gap:8px}
.m-modal-actions button{flex:1;height:38px;border:none;border-radius:6px;font-size:13px;cursor:pointer}
.m-modal-actions .ca{background:var(--d);color:#fff;font-weight:500}
.m-modal-actions .ca:active{opacity:.8}
.m-modal-actions .cc{background:#f0f2f5;color:var(--tx)}

/* ── TabBar ── */
.m-tabbar{position:fixed;bottom:0;left:0;right:0;max-width:480px;margin:0 auto;height:50px;background:#fff;display:flex;box-shadow:0 -1px 4px rgba(0,0,0,.06);z-index:100;border-top:1px solid #f0f0f0}
.m-tabbar a{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-decoration:none;color:var(--t3);font-size:9px;transition:color .15s}
.m-tabbar a.on{color:var(--p)}
.m-tabbar a span{font-size:20px;margin-bottom:1px}
</style>
</head>
<body class="iphone-host">
<%- include('partials/iphone_frame_start') %>

<div class="m-shell">

<div class="m-topbar">
<div class="tl">⚙️ 系统设置</div>
</div>

<div class="m-content">

<!-- 用户头像卡片 -->
<div class="m-avatar-card">
<div class="m-avatar"><%= user.name ? user.name.charAt(0) : '?' %></div>
<div class="m-avatar-info">
<div class="an"><%= user.name || '用户' %></div>
<div class="ae"><%= user.email || '-' %></div>
</div>
<div><span class="m-tag m-tag-<%= user.role==='admin'?'info':user.role==='auditor'?'mb':'ok' %>"><%= user.role==='admin'?'管理员':user.role==='auditor'?'审核员':'用户' %></span></div>
</div>

<!-- 详细信息 -->
<div class="m-card">
<div class="m-card-h">👤 个人资料</div>
<div class="m-row"><span class="rl">📧 邮箱</span><span class="rr"><%= user.email || '-' %></span></div>
<div class="m-row"><span class="rl">👤 姓名</span><span class="rr"><%= user.name || '-' %></span></div>
<div class="m-row"><span class="rl">🛡️ 角色</span><span class="rr"><%= user.role==='admin'?'管理员':user.role==='auditor'?'审核员':'用户' %></span></div>
<div class="m-row"><span class="rl">🆔 ID</span><span class="rr" style="font-size:10px;color:var(--t3)"><%= user.id || '-' %></span></div>
</div>

<!-- 系统信息 -->
<div class="m-card">
<div class="m-card-h">ℹ️ 系统信息</div>
<div class="m-row"><span class="rl">📌 版本</span><span class="rr">V4.0</span></div>
<div class="m-row"><span class="rl">🏗️ 架构</span><span class="rr">三层解耦</span></div>
<div class="m-row"><span class="rl">⚙️ 引擎</span><span class="rr">确定性规则</span></div>
<div class="m-row"><span class="rl">🔐 留痕</span><span class="rr">SHA-256 哈希链</span></div>
<div class="m-row"><span class="rl">🗄️ 数据库</span><span class="rr">SQLite</span></div>
</div>

<!-- 退出登录 -->
<button class="m-btn m-btn-d" onclick="confirmLogout()">🚪 退出登录</button>

<div class="m-footer">特种设备电梯安全管理AI系统</div>

</div>
</div>


<script>
function confirmLogout(){
  var overlay=document.createElement('div');
  overlay.className='m-overlay';
  overlay.onclick=function(e){if(e.target===overlay)removeOverlay(overlay)};

  var modal=document.createElement('div');
  modal.className='m-modal';
  modal.innerHTML=
    '<div class="m-modal-b">'+
      '<span class="mq">🚪</span>'+
      '<div class="mt">确认退出登录？</div>'+
      '<div class="md">退出后需要重新登录才能使用系统</div>'+
      '<div class="m-modal-actions">'+
        '<button class="cc" onclick="removeOverlay(this.closest(\'.m-overlay\'))">取消</button>'+
        '<button class="ca" onclick="doLogout()">退出</button>'+
      '</div>'+
    '</div>';
  overlay.appendChild(modal);
  document.body.appendChild(overlay);
}

function removeOverlay(overlay){
  if(overlay&&overlay.parentNode)overlay.parentNode.removeChild(overlay);
}

function doLogout(){
  window.location.href='/logout';
}
</script>

<%- include('partials/iphone_frame_end') %>
</body>
</html>
